# External PostGIS database (required)
DATABASE_URL=postgres://user:password@host:5432/tk103b

# Web UI auth (leave AUTH_PASSWORD empty to disable login)
AUTH_PASSWORD=changeme
# Fixed secret so sessions survive restarts — generate with:
#   openssl rand -hex 32
AUTH_SECRET=

# App
PORT=3001

# Published ports (docker-compose)
APP_PORT=9060
INGEST_PORT=9000
